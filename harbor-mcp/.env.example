# Personal Harbor hub API key. Mint one with `harbor auth login` (it prints
# and stores the key), or copy it from ~/.harbor/credentials.json.
HARBOR_API_KEY=

# Write tools (upload_job, publish_task, delete_job, ...) refuse unless this
# is "true". Read tools always work.
HARBOR_MCP_ENABLE_WRITES=false

# Environment used by the e2e test suite and evals: docker | modal.
# modal additionally needs Modal credentials (`modal token new` / ~/.modal.toml).
HARBOR_TEST_ENV=docker
